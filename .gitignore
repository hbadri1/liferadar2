.Spotlight-V100
.Trashes

######################
# Directories
######################
/bin/
/deploy/

######################
# Logs
######################
*.log*

######################
# Hosting secrets
######################
# ECS hosting config (AWS credentials, ECS infra settings)
/src/main/resources/config/hosting/aws/ecs/.env
# Lightsail hosting config
/src/main/resources/config/hosting/aws/lightsail/.env
# Lightsail SSH private keys
/src/main/resources/config/hosting/aws/lightsail/*.pem
# Rendered task definition (contains substituted secrets – never commit)
/src/main/resources/config/hosting/aws/ecs/task-definition.rendered.json
# Dev local secrets
/.env.dev.local
# App runtime secrets (prod: DB/JWT/mail; loaded by deploy scripts into task definition)
/src/main/resources/config/.env/.env.prod
# Local dev Spring Boot secrets (mail password etc.)
/src/main/resources/config/.env/.env.local

######################
# Others
######################
*.class
*.*~
*~
.merge_file*

