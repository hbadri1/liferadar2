# =============================================================================
# ECS hosting configuration (example / template)
# Copy this file to .env and fill real values.
#
# Contains AWS/ECS infrastructure settings ONLY.
# App runtime secrets (DB, JWT, mail, Spring profile) go in:
#   src/main/resources/config/.env/.env.prod  (copy from .env.prod.example)
#
# This example file IS committed; .env is gitignored.
# =============================================================================

# AWS
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=123456789012

# AWS credentials (choose ONE method – leave unused lines commented out)
#
# Option A: named profile from ~/.aws/config
#AWS_PROFILE=default
#
# Option B: static access key (for CI/CD or IAM users)
#AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
#AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
#AWS_SESSION_TOKEN=                  # only needed for STS temporary credentials
#
# Option C: leave all of the above blank and run "aws configure" / "aws sso login" beforehand.

# App / image
APP_NAME=liferadar
# Repository name only – do NOT include the full registry hostname.
# The scripts build the full URI automatically as:
#   <AWS_ACCOUNT_ID>.dkr.ecr.<AWS_REGION>.amazonaws.com/<ECR_REPOSITORY>
ECR_REPOSITORY=liferadar/apps
IMAGE_TAG=v0.1

# ECS
ECS_CLUSTER=liferadar-cluster
ECS_SERVICE=liferadar-service
ECS_TASK_FAMILY=liferadar-task
ECS_EXECUTION_ROLE_ARN=arn:aws:iam::123456789012:role/ecsTaskExecutionRole
ECS_TASK_ROLE_ARN=arn:aws:iam::123456789012:role/liferadarEcsTaskRole
ECS_SUBNET_IDS=subnet-aaaa1111,subnet-bbbb2222
ECS_SECURITY_GROUP_IDS=sg-aaaa1111
ECS_ASSIGN_PUBLIC_IP=ENABLED
ECS_DESIRED_COUNT=1
ECS_CPU=1024
ECS_MEMORY=2048

# Logs
LOG_GROUP_NAME=/ecs/liferadar
LOG_STREAM_PREFIX=ecs

