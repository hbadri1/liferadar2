<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260328143000-1-remove-default-user-account" author="copilot">
        <delete tableName="jhi_user_authority">
            <where>user_id IN (SELECT id FROM jhi_user WHERE login = 'user')</where>
        </delete>

        <delete tableName="jhi_user">
            <where>login = 'user'</where>
        </delete>
    </changeSet>
</databaseChangeLog>

