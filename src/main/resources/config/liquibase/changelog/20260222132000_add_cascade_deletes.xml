<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog-ext.xsd">
    <changeSet id="20260222132000-1" author="jhipster">
        <addColumn tableName="sub_life_pillar_item">
            <column name="sub_life_pillar_id" type="bigint"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260222132000-2" author="jhipster">
        <addForeignKeyConstraint baseColumnNames="sub_life_pillar_id"
                                 baseTableName="sub_life_pillar_item"
                                 constraintName="fk_sub_life_pillar_item__sub_life_pillar_id"
                                 referencedColumnNames="id"
                                 referencedTableName="sub_life_pillar"
                                 onDelete="CASCADE"
                                 />
    </changeSet>

    <changeSet id="20260222132000-3" author="jhipster">
        <dropForeignKeyConstraint baseTableName="life_evaluation"
                                  constraintName="fk_life_evaluation__sub_life_pillar_item_id"/>
        <addForeignKeyConstraint baseColumnNames="sub_life_pillar_item_id"
                                 baseTableName="life_evaluation"
                                 constraintName="fk_life_evaluation__sub_life_pillar_item_id"
                                 referencedColumnNames="id"
                                 referencedTableName="sub_life_pillar_item"
                                 onDelete="CASCADE"
                                 />
    </changeSet>

    <changeSet id="20260222132000-4" author="jhipster">
        <dropForeignKeyConstraint baseTableName="evaluation_decision"
                                  constraintName="fk_evaluation_decision__life_evaluation_id"/>
        <addForeignKeyConstraint baseColumnNames="life_evaluation_id"
                                 baseTableName="evaluation_decision"
                                 constraintName="fk_evaluation_decision__life_evaluation_id"
                                 referencedColumnNames="id"
                                 referencedTableName="life_evaluation"
                                 onDelete="CASCADE"
                                 />
    </changeSet>
</databaseChangeLog>

