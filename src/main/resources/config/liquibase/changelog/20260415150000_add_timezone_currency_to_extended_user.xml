<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <!--
        Added timezone and currency fields to extended_user table.
        JHipster will add changesets here (do not remove)
    -->
    <changeSet id="20260415150000-1" author="jhipster">
        <addColumn tableName="extended_user">
            <column name="timezone" type="varchar(50)" defaultValue="UTC">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="varchar(3)" defaultValue="USD">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>

