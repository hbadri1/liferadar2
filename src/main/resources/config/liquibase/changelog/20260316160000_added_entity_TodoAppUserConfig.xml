<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="20260316160000-1" author="copilot">
        <createTable tableName="todo_app_user_config">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="provider" type="varchar(40)">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="boolean">
                <constraints nullable="false"/>
            </column>
            <column name="access_token" type="varchar(1000)">
                <constraints nullable="true"/>
            </column>
            <column name="external_user_id" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
            <column name="default_project_id" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
            <column name="default_project_name" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="20260316160000-2" author="copilot">
        <addUniqueConstraint
            tableName="todo_app_user_config"
            columnNames="user_id, provider"
            constraintName="ux_todo_app_user_config_user_provider"
        />

        <addForeignKeyConstraint
            baseTableName="todo_app_user_config"
            baseColumnNames="user_id"
            constraintName="fk_todo_app_user_config__user_id"
            referencedTableName="jhi_user"
            referencedColumnNames="id"
            onDelete="CASCADE"
        />
    </changeSet>
</databaseChangeLog>

