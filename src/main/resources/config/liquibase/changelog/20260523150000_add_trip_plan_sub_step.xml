<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260523150000-1" author="copilot">
        <createTable tableName="trip_plan_sub_step">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="action_name" type="varchar(200)">
                <constraints nullable="false"/>
            </column>
            <column name="start_date" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="end_date" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="sequence" type="integer"/>
            <column name="notes" type="varchar(800)"/>
            <column name="step_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="trip_plan_sub_step" indexName="idx_trip_plan_sub_step_step_id">
            <column name="step_id"/>
        </createIndex>

        <addForeignKeyConstraint
            baseTableName="trip_plan_sub_step"
            baseColumnNames="step_id"
            referencedTableName="trip_plan_step"
            referencedColumnNames="id"
            constraintName="fk_trip_plan_sub_step__step_id"
            onDelete="CASCADE"/>
    </changeSet>
</databaseChangeLog>

