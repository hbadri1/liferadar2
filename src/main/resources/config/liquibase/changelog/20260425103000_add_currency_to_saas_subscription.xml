<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260425103000-1" author="liferadar">
        <addColumn tableName="saas_subscription">
            <column name="currency" type="VARCHAR(3)" remarks="Original subscription currency"/>
        </addColumn>

        <sql>
            UPDATE saas_subscription s
            SET currency = COALESCE(
                (
                    SELECT eu.currency
                    FROM extended_user eu
                    WHERE eu.id = s.owner_id
                ),
                'USD'
            )
            WHERE currency IS NULL;
        </sql>

        <addNotNullConstraint tableName="saas_subscription" columnName="currency" columnDataType="VARCHAR(3)"/>
    </changeSet>

</databaseChangeLog>

