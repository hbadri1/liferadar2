<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260325153000-1" author="copilot">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="todo_app_user_config"/>
            <not>
                <columnExists tableName="todo_app_user_config" columnName="default_project_name"/>
            </not>
        </preConditions>
        <addColumn tableName="todo_app_user_config">
            <column name="default_project_name" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>

