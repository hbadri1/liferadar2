# =============================================================================
# Application runtime configuration – PRODUCTION (example / template)
# Copy this file to .env.prod and fill real values.
#
# Used by: render-task-definition.ps1 (injects these as ECS task env vars)
# This example file IS committed; .env.prod is gitignored.
# =============================================================================

# Spring Boot profile & server
SPRING_PROFILES_ACTIVE=prod
CONTAINER_PORT=8080
JHIPSTER_SLEEP=0

# Database  (RDS / PostgreSQL)
DB_URL=jdbc:postgresql://<rds-host>:5432/<db-name>
DB_USERNAME=<db-user>
DB_PASSWORD=<db-password>

# Security – generate with: openssl rand -base64 64
JWT_BASE64_SECRET=<base64-encoded-256-bit-secret>

# Mail (SMTP)
SPRING_MAIL_PASSWORD=<smtp-password>

# TickTick OAuth callback URL
TICKTICK_REDIRECT_URI=https://<public-domain>/api/todoapps/ticktick/callback

