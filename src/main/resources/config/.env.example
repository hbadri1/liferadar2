# =============================================================================
# Environment secrets template
#
# Copy this file to:
#   .env.local  – for local development  (loaded by application-dev.yml)
#   .env.prod   – for production          (loaded by application-prod.yml + docker-compose)
#
# Then fill in the real values.
# Both .env.local and .env.prod are gitignored – never commit real secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# TickTick OAuth
# Register your app at https://developer.ticktick.com/manage
# -----------------------------------------------------------------------------
TICKTICK_CLIENT_ID=<replace>
TICKTICK_SECRET_ID=<replace>
# Dev default is http://localhost:8080/…  Override only for prod:
TICKTICK_REDIRECT_URI=https://<your-domain>/api/todoapps/ticktick/callback

# -----------------------------------------------------------------------------
# Mail – SMTP
# -----------------------------------------------------------------------------
SPRING_MAIL_PASSWORD=<replace-with-smtp-password>

# -----------------------------------------------------------------------------
# Security – JWT
# Generate with: openssl rand -base64 64
# (Required in prod; dev uses a hardcoded key in application-dev.yml)
# -----------------------------------------------------------------------------
JHIPSTER_SECURITY_AUTHENTICATION_JWT_BASE64_SECRET=<replace-with-base64-secret>

# -----------------------------------------------------------------------------
# Database  (prod only – dev uses H2 in-memory)
# -----------------------------------------------------------------------------
POSTGRES_DB=liferadar
POSTGRES_USER=<replace>
POSTGRES_PASSWORD=<replace>
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/liferadar
SPRING_DATASOURCE_USERNAME=<replace>
SPRING_DATASOURCE_PASSWORD=<replace>

# -----------------------------------------------------------------------------
# Public app URL  (used in e-mail links)
# -----------------------------------------------------------------------------
JHIPSTER_MAIL_BASE_URL=https://<your-domain>
TICKTICK_REDIRECT_URI=https://<your-domain>/api/todoapps/ticktick/callback

# -----------------------------------------------------------------------------
# Deployment – AWS / ECR / Lightsail
# (Only needed when running deploy scripts from this machine)
# -----------------------------------------------------------------------------
AWS_REGION=eu-central-1
AWS_ACCOUNT_ID=<replace>
LIGHTSAIL_IP=<replace>
AWS_ACCESS_KEY_ID=<replace>
AWS_SECRET_ACCESS_KEY=<replace>
ECR_REPOSITORY=liferadar/apps
IMAGE_TAG=<replace>
APP_IMAGE=<account>.dkr.ecr.<region>.amazonaws.com/liferadar/apps:<tag>

# -----------------------------------------------------------------------------
# Domain & TLS
# -----------------------------------------------------------------------------
DOMAIN_NAME=<your-domain>
LETSENCRYPT_EMAIL=<your-email>
